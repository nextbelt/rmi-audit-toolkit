# Copy this file to .env and fill in values.
# .env is gitignored — never commit it.
#
# For local dev with Docker Compose the defaults below work out of the box.
# Only the optional integrations (OpenAI, Supabase) need real values.

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite is the default for local dev (no extra service needed).
# Switch to Postgres for full production parity:
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/rmi_dev
DATABASE_URL=sqlite:////app/db/rmi_dev.db

# ── Security ─────────────────────────────────────────────────────────────────
# Generate a strong key:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-only-secret-change-before-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=RMI Audit Software
VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ── File handling ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=/app/uploads
REPORT_OUTPUT_DIR=/app/reports

# ── Optional integrations ─────────────────────────────────────────────────────
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
