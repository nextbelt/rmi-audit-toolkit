# Database (Railway provides this automatically; use a SQLite URL for local)
DATABASE_URL=sqlite:///./rmi_audit.db

# JWT signing key — MUST be unset or strong in production
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-strong-secret

# "development" or "production"
ENVIRONMENT=development

# Frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# Initial admin seed (used only by `python init_db.py`)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# Login rate limiting
LOGIN_RATE_LIMIT_PER_MIN=10

# Upload limits
UPLOAD_DIR=./uploads
REPORT_OUTPUT_DIR=./reports
MAX_UPLOAD_SIZE=52428800

# Storage backend: "local" (writes to UPLOAD_DIR) or "supabase" (private bucket).
# Production should be "supabase" — Railway containers are ephemeral and lose
# the upload dir on every redeploy.
STORAGE_BACKEND=local
SUPABASE_BUCKET=evidence

# Optional: OpenAI for AI-assisted scoring of narrative responses
OPENAI_API_KEY=

# Supabase (required when STORAGE_BACKEND=supabase)
#   SUPABASE_URL          — https://<ref>.supabase.co
#   SUPABASE_SERVICE_KEY  — service_role key (server-side ONLY; never ship to frontend)
#   SUPABASE_ANON_KEY     — anon public key (only the frontend uses this, via VITE_*)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
