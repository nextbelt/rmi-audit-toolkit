<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<style>
{{ fonts_css }}
{{ serif_css }}
:root {
  --ink: #0B2236;        /* deep navy ink — headlines */
  --panel: #08233f;      /* dark exhibit panel */
  --blue: #1F5AD0;       /* electric accent */
  --blue-soft: #EAF0FC;
  --peri: #DCE4FA;
  --body: #233340;       /* body text */
  --mute: #5E6E7B;       /* captions */
  --line: #D7DDE3;
  --line-2: #EAEEF1;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html, body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
body { font-family: 'Inter', Arial, sans-serif; color: var(--body); font-size: 10pt; line-height: 1.52; }
.serif { font-family: 'Playfair Display', Georgia, serif; }
p { margin: 0 0 9px; }
b, strong { color: var(--ink); font-weight: 600; }
a { color: var(--blue); text-decoration: none; }

.page { page-break-before: always; }
.avoid { page-break-inside: avoid; }
.mute { color: var(--mute); }
.spacer { height: 14px; }
.spacer-lg { height: 26px; }

/* ── Section header ── */
.sec { margin-bottom: 18px; }
.sec .eyebrow { font-size: 9px; letter-spacing: .28em; text-transform: uppercase; color: var(--blue); font-weight: 700; }
.sec h2 { font-family: 'Playfair Display', Georgia, serif; font-weight: 800; font-size: 31px; color: var(--ink);
  letter-spacing: -0.012em; margin-top: 9px; line-height: 1.04; }
.sec .kicker { font-size: 10.5pt; color: var(--mute); margin-top: 10px; max-width: 6in; }

/* numbered topic header (domains) */
.topic { display: flex; align-items: baseline; gap: 14px; margin: 0 0 8px; }
.topic .n { font-family: 'Playfair Display', Georgia, serif; font-size: 19px; font-weight: 700; color: var(--blue);
  font-variant-numeric: tabular-nums; }
.topic .sq { width: 10px; height: 10px; background: var(--blue); display: inline-block; margin-right: -4px; }
.topic h3 { font-family: 'Playfair Display', Georgia, serif; font-size: 25px; font-weight: 700; color: var(--ink); letter-spacing: -0.01em; }

/* ── Lead serif paragraph ── */
.lead { font-family: 'Playfair Display', Georgia, serif; font-weight: 400; font-size: 16pt; line-height: 1.36; color: var(--ink); }

/* ── Two-column body ── */
.cols2 { column-count: 2; column-gap: 26px; }
.cols2 p { margin: 0 0 9px; -webkit-column-break-inside: avoid; }

/* ── Stat callouts row ── */
.stats { display: flex; gap: 30px; margin: 22px 0 6px; flex-wrap: wrap; }
.stat .v { font-family: 'Playfair Display', Georgia, serif; font-weight: 800; font-size: 39px; color: var(--blue); line-height: 1; }
.stat .v .u { font-size: 15px; color: var(--mute); font-weight: 600; }
.stat .k { font-size: 9pt; color: var(--mute); margin-top: 7px; max-width: 1.7in; line-height: 1.4; }
.stat .k b { color: var(--ink); }

/* ── Maturity ladder ── */
.ladder { margin: 6px 0 2px; }
.ladder .track { position: relative; height: 13px; background: #ECEFF2; border-radius: 999px; }
.ladder .fill { position: absolute; left: 0; top: 0; bottom: 0; border-radius: 999px; }
.ladder .mk { position: absolute; top: -6px; bottom: -6px; width: 1.5px; background: #8A98A6; }
.ladder .mk .t { position: absolute; top: -15px; transform: translateX(-50%); font-size: 7.6pt; color: var(--mute);
  white-space: nowrap; letter-spacing: .02em; }
.ladder .pin { position: absolute; top: -25px; transform: translateX(-50%); text-align: center; }
.ladder .pin .v { font-family: 'Playfair Display', Georgia, serif; font-weight: 800; font-size: 13pt; color: var(--ink); line-height: 1; }
.ladder .pin .arw { display: block; width: 0; height: 0; margin: 2px auto 0; border-left: 5px solid transparent;
  border-right: 5px solid transparent; border-top: 6px solid var(--ink); }
.ladder .scale { display: flex; justify-content: space-between; margin-top: 18px; font-size: 7.8pt; color: var(--mute); }
.ladder .scale span { flex: 1; text-align: center; }
.ladder .scale span:first-child { text-align: left; }
.ladder .scale span:last-child { text-align: right; }
.ladder .scale b { display: block; color: var(--ink); font-weight: 700; font-size: 8.6pt; }

/* ── Exhibit framing ── */
.exhibit { margin: 6px 0 4px; }
.exhibit .lab { font-size: 9pt; color: var(--mute); }
.exhibit .hl { font-family: 'Inter', sans-serif; font-weight: 700; font-size: 12.5pt; color: var(--ink); margin: 4px 0 14px; }
.exhibit .src { font-size: 8pt; color: var(--mute); margin-top: 10px; line-height: 1.4; }
.exhibit .fm { font-size: 8.5pt; font-weight: 700; color: var(--ink); margin-top: 8px; }

/* dark exhibit panel */
.exhibit-dark { background: var(--panel); color: #EAF1F8; border-radius: 3px; padding: 22px 28px 16px; }
.exhibit-dark .lab { font-size: 8.5pt; letter-spacing: .22em; text-transform: uppercase; color: #7FA0C4; }
.exhibit-dark .hl { font-family: 'Playfair Display', Georgia, serif; font-weight: 700; font-size: 18pt; color: #fff; margin: 5px 0 3px; line-height: 1.12; }
.exhibit-dark .sub { font-size: 9pt; color: #B7C8DC; max-width: 4.7in; }
.exhibit-dark .src { font-size: 7.6pt; color: #6E8AA8; margin-top: 11px; line-height: 1.45; border-top: 1px solid rgba(255,255,255,0.12); padding-top: 8px; }
.exhibit-dark .src b { color: #9DB4CE; }

/* bars on dark */
.bars { margin: 14px 0 4px; }
.bar { display: grid; grid-template-columns: 1.7in 1fr 0.5in; align-items: center; gap: 14px; margin: 7px 0; }
.bar .lab2 { font-size: 9.2pt; color: #D2DEEC; }
.bar .lab2 .c { color: #7FA0C4; font-weight: 700; margin-right: 5px; }
.bar .track { height: 12px; background: rgba(255,255,255,0.09); border-radius: 2px; position: relative; }
.bar .fill { position: absolute; left: 0; top: 0; bottom: 0; border-radius: 2px; }
.bar .tgt { position: absolute; top: -3px; bottom: -3px; width: 1.5px; background: rgba(255,255,255,0.55); }
.bar .val { font-family: 'Playfair Display', Georgia, serif; font-weight: 700; font-size: 13pt; text-align: right; }
.darkstats { display: flex; gap: 34px; margin: 12px 0 2px; }
.darkstats .v { font-family: 'Playfair Display', Georgia, serif; font-weight: 800; font-size: 25pt; line-height: 1; color: #fff; }
.darkstats .v .u { font-size: 12pt; color: #9DB4CE; font-weight: 600; }
.darkstats .k { font-size: 8.4pt; color: #8FA8C2; margin-top: 6px; text-transform: uppercase; letter-spacing: .08em; }

/* ── Tables (McKinsey-minimal) ── */
table { width: 100%; border-collapse: collapse; font-size: 9.5pt; }
thead th { text-align: left; padding: 7px 12px 7px 0; font-weight: 700; font-size: 8.4pt; letter-spacing: .05em;
  text-transform: uppercase; color: var(--ink); border-bottom: 1.5px solid var(--ink); }
thead th.num { text-align: right; }
tbody td { padding: 8px 12px 8px 0; border-bottom: 1px solid var(--line-2); vertical-align: top; color: var(--body); }
.num { text-align: right; font-variant-numeric: tabular-nums; font-weight: 700; }

/* ── Radar / chart card ── */
.chartcard { border: 1px solid var(--line); border-radius: 4px; padding: 14px; background: #fff; }
.chartcard svg { width: 100%; height: auto; }
.chartcap { font-size: 8.4pt; color: var(--mute); text-align: center; margin-top: 6px; }
.cols { display: grid; grid-template-columns: 1.3fr 1fr; gap: 24px; align-items: start; }

/* ── Pull quote ── */
.pq { border-top: 2px solid var(--blue); padding-top: 22px; margin: 8px 0; }
.pq .q { font-family: 'Playfair Display', Georgia, serif; font-style: italic; font-weight: 500; font-size: 22pt;
  line-height: 1.32; color: var(--blue); }
.pq .a { font-size: 10pt; color: var(--mute); margin-top: 16px; }
.pq .a b { color: var(--ink); }

/* ── chips / levels ── */
.chip { display: inline-block; padding: 2px 9px; border-radius: 999px; font-size: 8.6pt; font-weight: 700; border: 1px solid transparent; }

/* ── findings / lists ── */
.find { padding: 11px 0 11px 22px; border-bottom: 1px solid var(--line-2); font-size: 10pt; position: relative; }
.find:before { content: ""; position: absolute; left: 0; top: 17px; width: 9px; height: 9px; background: var(--blue); }
.find:last-child { border-bottom: none; }

/* ── roadmap ── */
.phase { margin: 14px 0; page-break-inside: avoid; }
.phase .ph-h { font-family: 'Playfair Display', Georgia, serif; font-size: 15pt; font-weight: 700; color: var(--ink);
  border-left: 3px solid var(--blue); padding-left: 11px; }
.phase ol { margin: 10px 0 0 26px; }
.phase li { margin: 5px 0; font-size: 9.8pt; }
.callout { background: var(--blue-soft); border-left: 3px solid var(--blue); border-radius: 0 6px 6px 0;
  padding: 13px 16px; font-size: 9.8pt; color: var(--ink); margin: 14px 0; }

/* ── appendix tag ── */
.apx-tag { display: inline-block; background: var(--ink); color: #fff; font-size: 8.4pt; font-weight: 700;
  letter-spacing: .12em; padding: 3px 10px; border-radius: 3px; text-transform: uppercase; }

/* ── contents ── */
.contents { padding-top: 0.3in; }
.contents h1 { font-family: 'Playfair Display', Georgia, serif; font-size: 52px; font-weight: 800; color: var(--ink); }
.toc { margin-top: 0.6in; max-width: 5.6in; }
.toc .grp { margin-bottom: 22px; }
.toc .grp .gh { font-family: 'Playfair Display', Georgia, serif; font-size: 17pt; font-weight: 700; color: var(--ink);
  border-bottom: 1px solid var(--line); padding-bottom: 7px; margin-bottom: 4px; }
.toc .row { display: flex; align-items: baseline; gap: 12px; padding: 6px 0; font-size: 10.5pt; }
.toc .row .n { font-variant-numeric: tabular-nums; color: var(--blue); font-weight: 700; width: 24px; }
.toc .row .t { color: var(--body); flex: 1; }
</style>
</head>
<body>

{% set sd_sorted = (domains|selectattr('score')|sort(attribute='score'))|list %}
{% set weakest = sd_sorted[0] if sd_sorted else None %}
{% set strongest = sd_sorted[-1] if sd_sorted else None %}
{% set below_target = (domains|selectattr('score')|selectattr('score','lt',3.0)|list)|length %}

{% macro level_tag(level, score) -%}
<span class="chip" style="background:{{ level.color }}16; color:{{ level.color }}; border-color:{{ level.color }}40;">{{ '%.2f'|format(score) if score is not none else '—' }} · L{{ level.n }}</span>
{%- endmacro %}

<!-- ============ CONTENTS ============ -->
<section class="contents">
  <h1>Contents</h1>
  <div class="toc">
    <div class="grp">
      <div class="gh">Assessment</div>
      <div class="row"><span class="n">01</span><span class="t">Executive summary</span></div>
      <div class="row"><span class="n">02</span><span class="t">Maturity scorecard — five domains</span></div>
      <div class="row"><span class="n">03</span><span class="t">Pillar &amp; domain profile</span></div>
    </div>
    <div class="grp">
      <div class="gh">Where the score comes from</div>
      <div class="row"><span class="n">04</span><span class="t">Domain &amp; subdomain detail</span></div>
      <div class="row"><span class="n">05</span><span class="t">Key findings</span></div>
      <div class="row"><span class="n">06</span><span class="t">Priority fixes — lowest-scoring items</span></div>
      {% if cmms %}<div class="row"><span class="n">07</span><span class="t">CMMS data analysis</span></div>{% endif %}
    </div>
    <div class="grp">
      <div class="gh">The path forward</div>
      <div class="row"><span class="n">08</span><span class="t">Strategic roadmap — 30 / 60 / 90 day</span></div>
      <div class="row"><span class="n">09</span><span class="t">Evidence &amp; assurance summary</span></div>
    </div>
    <div class="grp">
      <div class="gh">Appendices</div>
      <div class="row"><span class="n">A</span><span class="t">Methodology &amp; scoring framework</span></div>
      <div class="row"><span class="n">B</span><span class="t">Full subdomain register</span></div>
      <div class="row"><span class="n">C</span><span class="t">Scope, coverage &amp; limitations</span></div>
    </div>
  </div>
</section>

<!-- ============ 01 EXECUTIVE SUMMARY ============ -->
<section class="page">
  <div class="sec"><div class="eyebrow">01 — Executive summary</div><h2>Where {{ site }} stands</h2></div>

  <p class="lead">{{ site }} achieved an overall Reliability Maturity Index of
    {{ '%.2f'|format(overall) if overall is not none else 'N/A' }} of 5.0&mdash;{% if overall_level.n %}Level {{ overall_level.n }}, {{ overall_level.label|lower }} maturity{% else %}not yet scored{% endif %}.
    {% if strongest and weakest %}{{ strongest.name }} is the strongest domain; {{ weakest.name|lower }} is the clearest drag on the score and the highest-leverage place to start.{% endif %}</p>

  {% if overall is not none %}
  <div class="spacer"></div>
  <div class="ladder avoid">
    <div class="track">
      <div class="fill" style="width: {{ (overall/5*100)|round(1) }}%; background: {{ overall_level.color }};"></div>
      <div class="mk" style="left: 60%;"><span class="t">3.0 floor</span></div>
      <div class="mk" style="left: 80%;"><span class="t">4.0 target</span></div>
      <div class="pin" style="left: {{ (overall/5*100)|round(1) }}%;"><span class="v">{{ '%.2f'|format(overall) }}</span><span class="arw"></span></div>
    </div>
    <div class="scale">
      <span><b>1</b> Reactive</span><span><b>2</b> Emerging</span><span><b>3</b> Systematic</span><span><b>4</b> Proactive</span><span><b>5</b> World-class</span>
    </div>
  </div>
  <p class="mute" style="font-size: 9pt; margin-top: 16px;">Maturity is scored 1–5 and measured against <b>world-class (5.0)</b>. The <b>3.0</b> mark is the systematic floor&mdash;the ISO 55001-aligned minimum where practices are documented and repeatable; <b>4.0</b> is the recommended near-term target. {{ site }} sits <b>{{ '%.2f'|format(overall_gap) }} below world-class</b>{% if below_floor %} with <b>{{ below_floor }} of {{ domains|length }}</b> domains still under the systematic floor{% endif %}.</p>
  {% endif %}

  <div class="stats">
    <div class="stat"><div class="v">{{ '%.2f'|format(overall) if overall is not none else '—' }}<span class="u"> / 5</span></div><div class="k"><b>Overall RMI</b> — {{ overall_level.label|lower }}{% if confidence_band[0] is not none %} · band {{ '%.1f'|format(confidence_band[0]) }}–{{ '%.1f'|format(confidence_band[1]) }}{% endif %}</div></div>
    <div class="stat"><div class="v">{{ '%.2f'|format(overall_gap) if overall_gap is not none else '—' }}</div><div class="k"><b>Gap to world-class</b> — points to 5.0</div></div>
    <div class="stat"><div class="v">{{ confidence ~ '%' if confidence is not none else '—' }}</div><div class="k"><b>Scoring confidence</b> — evidence support</div></div>
    <div class="stat"><div class="v">{{ iso_readiness ~ '%' if iso_readiness is not none else '—' }}</div><div class="k"><b>ISO 55001 readiness</b> — at/above the 3.0 floor</div></div>
  </div>

  <div class="spacer"></div>
  <div class="cols2">
    <p>This report is an independent evaluation of the maintenance and reliability management system at
      <b>{{ client }} — {{ site }}</b>, conducted by {{ firm.name }} using the Reliability Maturity Index (RMI)
      framework: five domains and fifteen subdomains, each scored 1–5 against defined maturity anchors.</p>
    <p>Responses are weighted by respondent role so the people closest to the work carry appropriate weight, and
      high-maturity claims are credited only where supporting evidence was verified&mdash;so the rating is defensible,
      not aspirational.{% if responses %} The score rests on <b>{{ responses }}</b> scored interview responses{% if cmms %} and {{ cmms|length }} CMMS data snapshot(s){% endif %}.{% endif %}</p>
    <p>The sections that follow break the score down by pillar and domain, name the specific items dragging each area
      down, and set out a prioritized 30/60/90-day roadmap to advance maturity{% if weakest %}, starting with {{ weakest.name|lower }}{% endif %}.</p>
    {% if velocity and velocity.get('status') == 'calculated' %}<p><b>Maturity velocity:</b> {{ '%+.2f'|format(velocity.delta) }} RMI versus the prior assessment ({{ velocity.interpretation }}).</p>{% endif %}
  </div>
</section>

<!-- ============ 02 SCORECARD (dark exhibit) ============ -->
<section class="page">
  <div class="sec"><div class="eyebrow">02 — Maturity scorecard</div><h2>Five domains, one index</h2></div>

  <div class="exhibit-dark avoid">
    <div class="lab">Exhibit 1 · The reliability maturity index</div>
    <div class="hl">Each domain&rsquo;s distance to world-class</div>
    <div class="sub">Domains scored 1–5 and rolled up from three subdomains each. The full bar is world-class (5.0); the markers are the <b style="color:#cfe0f4">3.0</b> systematic floor and the <b style="color:#cfe0f4">4.0</b> proactive target. The empty bar is the headroom that remains.</div>
    <div class="bars">
      {% for d in domains %}
      <div class="bar">
        <div class="lab2"><span class="c">{{ d.code }}</span>{{ d.name }}</div>
        <div class="track"><div class="fill" style="width: {{ ((d.score or 0)/5*100)|round(1) }}%; background: {{ d.level.color }};"></div><div class="tgt" style="left: 60%;"></div><div class="tgt" style="left: 80%; background: rgba(255,255,255,0.32);"></div></div>
        <div class="val" style="color: {{ d.level.color }};">{{ '%.2f'|format(d.score) if d.score is not none else '—' }}</div>
      </div>
      {% endfor %}
    </div>
    <div class="darkstats">
      <div><div class="v">{{ '%.2f'|format(overall) if overall is not none else '—' }}<span class="u"> / 5</span></div><div class="k">Overall RMI</div></div>
      <div><div class="v">{{ '%.2f'|format(overall_gap) if overall_gap is not none else '—' }}</div><div class="k">To world-class</div></div>
      {% if confidence is not none %}<div><div class="v">{{ confidence }}<span class="u">%</span></div><div class="k">Confidence</div></div>{% endif %}
      {% if peer_mean %}<div><div class="v">{{ '%.1f'|format(peer_mean) }}</div><div class="k">Peer mean</div></div>{% endif %}
    </div>
    <div class="src"><b>Bands:</b> 1 Reactive · 2 Emerging · 3 Systematic · 4 Proactive · 5 World-class. Role-weighted interview responses, evidence-verified.{% if not peer_mean %} Peer benchmarking unlocks once comparable sites are assessed.{% endif %} &nbsp; <b>{{ firm.name }}</b></div>
  </div>

  <div class="spacer"></div>

  <div class="exhibit avoid">
    <div class="lab">Exhibit 2</div>
    <div class="hl">Domain detail and maturity band</div>
    <table class="avoid">
      <thead><tr><th>Domain</th><th class="num">Score</th><th>Maturity band</th><th>Next milestone</th><th class="num">vs. floor</th><th class="num">To 5.0</th></tr></thead>
      <tbody>
        {% for d in domains %}
        {% set nx = 3.0 if (d.score or 0) < 3.0 else (4.0 if (d.score or 0) < 4.0 else 5.0) %}
        {% set nxlabel = 'Systematic' if nx == 3.0 else ('Proactive' if nx == 4.0 else 'World-class') %}
        <tr>
          <td><b>{{ d.code }}</b> &nbsp;{{ d.name }}</td>
          <td class="num" style="color: {{ d.level.color }}">{{ '%.2f'|format(d.score) if d.score is not none else '—' }}</td>
          <td>{% if d.level.n %}Level {{ d.level.n }} — {{ d.level.label }}{% else %}—{% endif %}</td>
          <td class="mute">{% if d.score is not none %}{{ '%.1f'|format(nx) }} {{ nxlabel }} <span style="color:var(--blue)">(+{{ '%.2f'|format(nx - d.score) }})</span>{% else %}—{% endif %}</td>
          <td class="num" style="color: {{ '#1E7A52' if d.score and d.score >= 3.0 else '#C0392B' }}">{% if d.score is not none %}{{ '✓ cleared' if d.score >= 3.0 else '%+.2f'|format(d.score - 3.0) }}{% else %}—{% endif %}</td>
          <td class="num mute">{{ '%.2f'|format(5.0 - d.score) if d.score is not none else '—' }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    <div class="src"><b>Next milestone</b> = the next maturity band and the gain needed to reach it. <b>vs. floor</b> = clearance over the 3.0 systematic floor. <b>To 5.0</b> = points of headroom remaining to world-class. &nbsp; <b>{{ firm.name }}</b></div>
  </div>
</section>

<!-- ============ 03 PILLAR & DOMAIN PROFILE ============ -->
<section class="page">
  <div class="sec"><div class="eyebrow">03 — Profile</div><h2>People, process &amp; technology</h2>
    <div class="kicker">The five domains roll up to three executive pillars. The radar shows the shape of maturity at a glance—where the operation is balanced, and where it is lopsided.</div></div>

  <div class="stats">
    {% for p in pillars %}
    <div class="stat"><div class="v" style="color: {{ p.level.color }}">{{ '%.2f'|format(p.score) if p.score is not none else '—' }}</div><div class="k"><b>{{ p.name }}</b> — {% if p.level.n %}{{ p.level.label|lower }}{% else %}n/a{% endif %} · {{ p.codes|join(' + ') }}</div></div>
    {% endfor %}
  </div>

  <div class="spacer-lg"></div>
  <div class="cols">
    <div class="chartcard avoid">{{ domain_radar|safe }}<div class="chartcap">Dashed = {{ 'peer mean' if peer_mean else '3.0 systematic floor' }} · outer ring = 5.0 world-class</div></div>
    <div class="chartcard avoid">{{ pillar_radar|safe }}<div class="chartcap">People · Process · Technology · outer ring = 5.0 world-class</div></div>
  </div>
  <div class="exhibit"><div class="src">Exhibit 3 · Domain and pillar maturity profiles. People = Workforce + Leadership; Process = Work Management + Strategy &amp; Governance; Technology = Asset Information. &nbsp; <b>{{ firm.name }}</b></div></div>
</section>

<!-- ============ 04 DOMAIN & SUBDOMAIN DETAIL ============ -->
<section class="page">
  <div class="sec"><div class="eyebrow">04 — Detail</div><h2>Inside each domain</h2>
    <div class="kicker">Every domain, broken to its three subdomains with the maturity band and any score cap applied. Capped subdomains are where a single critical weakness limits credit despite strength elsewhere.</div></div>

  {% for d in domains %}
  <div class="avoid" style="margin-bottom: 22px;">
    <div class="topic"><span class="n">{{ '%02d'|format(loop.index) }}</span><span class="sq"></span><h3>{{ d.name }}</h3></div>
    <p class="mute" style="font-size: 9.6pt; margin: 0 0 9px;">{{ d.code }} &nbsp;·&nbsp; {{ level_tag(d.level, d.score) }}
      {% if d.score is not none %}&nbsp;&nbsp;{% if d.score >= 3.0 %}At or above the systematic floor.{% else %}{{ '%.2f'|format(3.0 - d.score) }} below the 3.0 floor.{% endif %}{% endif %}</p>
    <table>
      <thead><tr><th>Subdomain</th><th class="num">Score</th><th>Band</th><th>Cap / note</th></tr></thead>
      <tbody>
        {% for sd in d.subdomains %}
        <tr>
          <td><b>{{ sd.code }}</b> &nbsp;{{ sd.name }}</td>
          <td class="num" style="color: {{ sd.level.color }}">{{ '%.2f'|format(sd.score) if sd.score is not none else '—' }}</td>
          <td>{{ sd.level.label }}</td>
          <td class="mute">{% if sd.cap_applied %}{{ (sd.cap_reason or 'Capped')[:64] }}{% else %}—{% endif %}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endfor %}
</section>

<!-- ============ 05 KEY FINDINGS ============ -->
{% if findings %}
<section class="page">
  <div class="sec"><div class="eyebrow">05 — Findings</div><h2>What the score is telling you</h2></div>
  {% for f in findings %}<div class="find">{{ f|safe }}</div>{% endfor %}
</section>
{% endif %}

<!-- ============ 06 PRIORITY FIXES ============ -->
{% if priority_fixes %}
<section class="page">
  <div class="sec"><div class="eyebrow">06 — Quick wins</div><h2>Priority fixes</h2>
    <div class="kicker">The specific lowest-scoring items in each domain, weakest first—the fastest, most concrete moves. Pair these tactical fixes with the strategic roadmap that follows.</div></div>
  {% for g in priority_fixes %}
  <div class="exhibit avoid" style="margin-top: 16px;">
    <div class="topic" style="margin-bottom: 10px;"><span class="n">{{ g.code }}</span><span class="sq"></span><h3 style="font-size: 21px;">{{ g.name }}</h3></div>
    <table>
      <thead><tr><th>Lowest-scoring item</th><th class="num">Score</th><th>Recommended action</th></tr></thead>
      <tbody>
        {% for it in g.rows %}
        <tr>
          <td style="width: 38%;"><b>{{ it.code }}</b> &nbsp;{{ it.text[:118] }}{% if it.text|length > 118 %}…{% endif %}</td>
          <td class="num" style="color: {{ it.level.color }}">{{ '%.1f'|format(it.score) }}</td>
          <td>{{ it.fix }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endfor %}
</section>
{% endif %}

<!-- ============ CMMS ============ -->
{% if cmms %}
<section class="page">
  <div class="sec"><div class="eyebrow">07 — CMMS data</div><h2>What the maintenance data shows</h2></div>
  {% for c in cmms %}
  <div class="exhibit avoid" style="margin-bottom: 18px;">
    <div class="lab">{{ c.kind }} · {{ c.filename }}</div>
    <div class="hl">{{ c.records }} records analyzed</div>
    {% if c.kpis %}
    <table>
      <thead><tr><th>Metric</th><th class="num">Value</th><th>Assessment</th></tr></thead>
      <tbody>{% for label, value, sev in c.kpis %}<tr><td>{{ label }}</td><td class="num">{{ value }}</td><td class="mute">{{ sev }}</td></tr>{% endfor %}</tbody>
    </table>
    {% endif %}
    {% if c.bad_actors %}<div class="src"><b>Top bad actors by work order volume:</b> {% for k, v in c.bad_actors %}{{ k }} ({{ v }}){% if not loop.last %} · {% endif %}{% endfor %}</div>{% endif %}
  </div>
  {% endfor %}
</section>
{% endif %}

<!-- ============ PULL QUOTE ============ -->
<section class="page">
  <div style="height: 1.4in;"></div>
  <div class="pq">
    <div class="q">{% if weakest and overall is not none %}“Closing the gap in {{ weakest.name|lower }} is the single highest-leverage move available to {{ site }} over the next 90 days&mdash;enough, on its own, to lift the index toward the next maturity band.”{% else %}“Reliability maturity compounds: the discipline that raises one domain tends to lift the others. Start where the evidence points, and re-baseline in 90 days.”{% endif %}</div>
    <div class="a">— {{ firm.name }} Reliability Practice{% if lead_assessor and lead_assessor != '—' %}, {{ lead_assessor }}{% endif %}</div>
  </div>
  <div class="spacer-lg"></div>
  {% if blind_spots %}
  <div class="exhibit avoid">
    <div class="lab">Exhibit · Cultural alignment</div>
    <div class="hl" style="font-family:'Playfair Display',serif; font-size: 16pt;">Where frontline and leadership see it differently</div>
    <table>
      <thead><tr><th>Subdomain</th><th class="num">Role spread</th><th>Severity</th></tr></thead>
      <tbody>{% for b in blind_spots %}<tr><td>{{ b.get('subdomain','') }}</td><td class="num">{{ '%.2f'|format(b.get('variance',0)) }}</td><td>{{ (b.get('severity') or '')|title }}</td></tr>{% endfor %}</tbody>
    </table>
    <div class="src">Large role spreads signal misalignment between how the work is experienced and how it is managed. &nbsp; <b>{{ firm.name }}</b></div>
  </div>
  {% endif %}
</section>

<!-- ============ 08 ROADMAP ============ -->
<section class="page">
  <div class="sec"><div class="eyebrow">08 — The path forward</div><h2>Strategic roadmap</h2>
    <div class="kicker">A sequenced 30 / 60 / 90-day plan. Assign an executive sponsor per phase, run a weekly cadence, and re-baseline the RMI at 90 days to measure velocity.</div></div>

  {% if roadmap.weakest %}<div class="callout"><b>Start here.</b> Concentrate first on {{ roadmap.weakest|join(', ') }}&mdash;the lowest-scoring domains&mdash;while protecting today’s strengths.</div>{% endif %}

  {% for key in ['30','60','90'] %}
  {% set ph = roadmap.phases[key] %}
  {% if ph.actions %}
  <div class="phase">
    <div class="ph-h">{{ ph.title }}</div>
    <ol>{% for act in ph.actions %}<li>{{ act }}</li>{% endfor %}</ol>
  </div>
  {% endif %}
  {% endfor %}
</section>

<!-- ============ 09 EVIDENCE ============ -->
<section class="page">
  <div class="sec"><div class="eyebrow">09 — Assurance</div><h2>Evidence &amp; assurance</h2></div>
  <div class="cols">
    <div>
      <table class="avoid">
        <thead><tr><th>Evidence status</th><th class="num">Responses</th></tr></thead>
        <tbody>{% for e in evidence %}<tr><td>{{ e.label }}</td><td class="num">{{ e.count }}</td></tr>{% endfor %}</tbody>
      </table>
    </div>
    <div>
      <p class="mute" style="font-size: 9.6pt;">Scores of 4 or above on evidence-required questions are credited only where supporting evidence has been verified. Unverified claims are conservatively moderated, and weakest-link caps prevent a single critical failure from being masked by strength elsewhere&mdash;keeping the maturity rating defensible.</p>
    </div>
  </div>
</section>

<!-- ============ APPENDIX A ============ -->
<section class="page">
  <span class="apx-tag">Appendix A</span>
  <div class="sec" style="margin-top: 12px;"><h2>Methodology &amp; scoring</h2></div>
  <p class="lead" style="font-size: 14pt;">The RMI framework scores reliability maturity across five domains and fifteen subdomains on a 1–5 scale.</p>
  <div class="spacer"></div>
  <table class="avoid">
    <thead><tr><th class="num">Level</th><th>Band</th><th>Meaning</th></tr></thead>
    <tbody>
      <tr><td class="num" style="color:#C0392B">1</td><td>1.00–1.99 · Reactive</td><td>Run-to-failure; firefighting; minimal planning.</td></tr>
      <tr><td class="num" style="color:#D9822B">2</td><td>2.00–2.99 · Emerging</td><td>Basic preventive practices exist but are inconsistent.</td></tr>
      <tr><td class="num" style="color:#1C78B5">3</td><td>3.00–3.59 · Systematic</td><td>Documented, repeatable processes followed across the site.</td></tr>
      <tr><td class="num" style="color:#2E8C6A">4</td><td>3.60–4.29 · Proactive</td><td>Condition- and risk-based; metrics drive decisions.</td></tr>
      <tr><td class="num" style="color:#1E7A52">5</td><td>4.30–5.00 · Prescriptive</td><td>Predictive/prescriptive; continuous improvement embedded.</td></tr>
    </tbody>
  </table>
  <div class="spacer"></div>
  <div class="cols2">
    <p><b>Targets.</b> Maturity is benchmarked against <b>world-class (5.0)</b>. The 3.0 line is the systematic floor — the ISO 55001-aligned minimum for documented, repeatable practice — and 4.0 is the recommended near-term target. Every domain is reported against all three, so clearing the floor is never mistaken for being done.</p>
    <p><b>Role weighting.</b> Responses are weighted by respondent role (technician, supervisor, manager, planner, reliability engineer) so the people closest to the work carry appropriate weight.</p>
    <p><b>Evidence policy.</b> A high score (≥4) on an evidence-required question is credited only when supporting evidence is verified; otherwise it is moderated. Weakest-link and cross-domain caps prevent a single critical failure (e.g. no stop-work authority, no CMMS) from being masked by strong scores elsewhere.</p>
    <p><b>Confidence band.</b> Scoring confidence is reduced by evidence gaps and cross-role variance; the band shown is the overall score ± (1 − confidence).</p>
  </div>
</section>

<!-- ============ APPENDIX B ============ -->
<section class="page">
  <span class="apx-tag">Appendix B</span>
  <div class="sec" style="margin-top: 12px;"><h2>Full subdomain register</h2></div>
  <table>
    <thead><tr><th>Code</th><th>Subdomain</th><th>Domain</th><th class="num">Score</th><th>Band</th><th>Cap / note</th></tr></thead>
    <tbody>
      {% for d in domains %}{% for sd in d.subdomains %}
      <tr>
        <td><b>{{ sd.code }}</b></td><td>{{ sd.name }}</td><td class="mute">{{ d.code }}</td>
        <td class="num" style="color: {{ sd.level.color }}">{{ '%.2f'|format(sd.score) if sd.score is not none else '—' }}</td>
        <td>{{ sd.level.label }}</td>
        <td class="mute">{% if sd.cap_applied %}{{ (sd.cap_reason or 'Capped')[:48] }}{% else %}—{% endif %}</td>
      </tr>
      {% endfor %}{% endfor %}
    </tbody>
  </table>
</section>

<!-- ============ APPENDIX C ============ -->
<section class="page">
  <span class="apx-tag">Appendix C</span>
  <div class="sec" style="margin-top: 12px;"><h2>Scope, coverage &amp; limitations</h2></div>
  <table class="avoid">
    <tbody>
      <tr><td style="width: 36%"><b>Client</b></td><td>{{ client }}</td></tr>
      <tr><td><b>Site</b></td><td>{{ site }}</td></tr>
      <tr><td><b>Region</b></td><td>{{ region }}</td></tr>
      <tr><td><b>Industry</b></td><td>{{ industry }}</td></tr>
      <tr><td><b>Assessment mode</b></td><td>{{ mode }}</td></tr>
      <tr><td><b>Lead assessor</b></td><td>{{ lead_assessor }}</td></tr>
      <tr><td><b>Assessment date</b></td><td>{{ assessment_date }}</td></tr>
      <tr><td><b>Report generated</b></td><td>{{ report_date }}</td></tr>
      <tr><td><b>Scored responses</b></td><td>{{ responses }}</td></tr>
      <tr><td><b>CMMS snapshots</b></td><td>{{ cmms|length }}</td></tr>
    </tbody>
  </table>
  <p class="mute" style="font-size: 9.4pt; margin-top: 14px;">This assessment reflects the conditions and information made available as of the assessment date and is intended for the internal use of {{ client }} and {{ firm.name }}. Findings are based on interview responses, observed practices, and any CMMS data provided; they do not constitute a certification or guarantee of outcomes. Prepared by {{ firm.name }} — {{ firm.website.replace('https://','') }}.</p>
</section>

</body>
</html>
