<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<style>
{{ fonts_css }}
{{ serif_css }}
* { margin: 0; padding: 0; box-sizing: border-box; }
@page { size: Letter; margin: 0; }
html, body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
body { font-family: 'Inter', Arial, sans-serif; }
.serif { font-family: 'Playfair Display', Georgia, serif; }

/* ============ COVER ============ */
.cover {
  position: relative; width: 8.5in; height: 11in; overflow: hidden; color: #fff;
  background: radial-gradient(125% 90% at 88% 4%, #2f6fe6 0%, #1751b8 30%, #0b2e6b 58%, #06183a 80%, #040f24 100%);
}
.cover::before { content: ""; position: absolute; inset: 0;
  background-image: repeating-linear-gradient(118deg, rgba(255,255,255,0.045) 0 1.5px, transparent 1.5px 30px); opacity: 0.9; }
.cover::after { content: ""; position: absolute; right: -2in; bottom: -2.2in; width: 7.2in; height: 7.2in; border-radius: 50%;
  background: repeating-radial-gradient(circle at center, rgba(150,195,255,0.10) 0 1px, transparent 1px 18px); opacity: 0.7; }
.inner { position: relative; z-index: 2; height: 100%; padding: 0.85in 0.85in 0.7in; display: flex; flex-direction: column; }

.brand { display: flex; align-items: center; gap: 13px; }
.brand img { width: 46px; height: 46px; filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4)); }
.brand .nm { font-family: 'Playfair Display', Georgia, serif; font-size: 23px; font-weight: 800; line-height:1; }
.brand .tg { font-size: 8.5px; color: #AFC6E8; letter-spacing: .2em; text-transform: uppercase; margin-top: 5px; }

.titlewrap { margin-top: 1.3in; }
.eyebrow { font-size: 11px; letter-spacing: .34em; text-transform: uppercase; color: #8FB4E6; font-weight: 600; }
.title { font-family: 'Playfair Display', Georgia, serif; font-weight: 800; font-size: 70px; line-height: 1.0;
  letter-spacing: -0.005em; margin-top: 20px; text-shadow: 0 3px 26px rgba(0,0,0,0.28); }
.subtitle { font-family: 'Playfair Display', Georgia, serif; font-weight: 400; font-style: italic; font-size: 27px; color: #CFE0F4; margin-top: 16px; }
.meta-edition { font-size: 12.5px; color: #9DBAE0; margin-top: 22px; line-height: 1.7; }
.meta-edition b { color: #DCE9F8; font-weight: 600; }

.client { margin-top: auto; }
.client .lbl { font-size: 10px; letter-spacing: .24em; text-transform: uppercase; color: #7FA6D8; }
.client .nm { font-family: 'Playfair Display', Georgia, serif; font-size: 34px; font-weight: 700; margin-top: 8px; line-height: 1.08; }
.client .st { font-size: 14px; color: #B8CCE6; margin-top: 6px; }
.scoretab { margin-top: 26px; display: inline-flex; align-items: baseline; gap: 14px; border-top: 1px solid rgba(160,195,235,0.28); padding-top: 16px; }
.scoretab .big { font-family: 'Playfair Display', Georgia, serif; font-weight: 800; font-size: 44px; line-height: 1; color: {{ overall_level.color if overall_level.n else '#CFE0F4' }}; }
.scoretab .of { font-size: 14px; color: #9DBAE0; }
.scoretab .lvl { font-size: 12px; color: #C7D9EE; }
.scoretab .lvl .b { display:block; font-size: 9px; letter-spacing:.22em; text-transform:uppercase; color:#7FA6D8; margin-bottom:3px; }
.foot { margin-top: 24px; display: flex; justify-content: space-between; align-items: center; font-size: 10px; color: #7E9AC0; letter-spacing: .03em; }

/* ============ STATEMENT (periwinkle, full bleed) ============ */
.statement { page-break-before: always; position: relative; width: 8.5in; height: 11in; overflow: hidden;
  background: #DCE4FA; color: #1A3CA8; padding: 1.45in 1.05in 0.9in; display: flex; flex-direction: column; }
.statement .q { font-family: 'Playfair Display', Georgia, serif; font-weight: 600; font-size: 35px; line-height: 1.22;
  letter-spacing: -0.005em; max-width: 6.3in; }
.statement .by { font-size: 13px; color: #3A4F9E; margin-top: 28px; }
.statement .by b { color: #1A3CA8; font-weight: 600; }
.statement .stats { margin-top: auto; display: flex; gap: 0.7in; }
.statement .stat .v { font-family: 'Playfair Display', Georgia, serif; font-weight: 800; font-size: 46px; line-height: 1; color: #1F46C8; }
.statement .stat .k { font-size: 10.5px; color: #41539C; margin-top: 7px; max-width: 1.7in; line-height: 1.4; }
.statement .copyright { font-size: 8.5px; color: #5566AE; margin-top: 26px; line-height: 1.5; max-width: 3.3in; }
</style>
</head>
<body>
  {% set sd_sorted = (domains|selectattr('score')|sort(attribute='score'))|list %}
  {% set weakest = sd_sorted[0] if sd_sorted else None %}
  {% set p_sorted = (pillars|selectattr('score')|sort(attribute='score'))|list %}
  {% set top_pillar = p_sorted[-1] if p_sorted else None %}

  <!-- COVER -->
  <div class="cover">
    <div class="inner">
      <div class="brand">
        {% if logo %}<img src="{{ logo }}" alt="NextBelt" />{% endif %}
        <div>
          <div class="nm">{{ firm.name.replace(' LLC','') }}</div>
          <div class="tg">{{ firm.tagline }}</div>
        </div>
      </div>

      <div class="titlewrap">
        <div class="eyebrow">Reliability &amp; Asset Management</div>
        <div class="title">Reliability<br/>Maturity Index</div>
        <div class="subtitle">Executive Audit Outlook</div>
        <div class="meta-edition"><b>{{ report_date }}</b> &nbsp;·&nbsp; {{ mode }} assessment{% if industry and industry != '—' %} &nbsp;·&nbsp; {{ industry }}{% endif %}</div>
      </div>

      <div class="client">
        <div class="lbl">Prepared for</div>
        <div class="nm">{{ client }}</div>
        <div class="st">{{ site }}{% if region and region != '—' %} &nbsp;·&nbsp; {{ region }}{% endif %}</div>
        <div class="scoretab">
          <div class="big">{{ '%.2f'|format(overall) if overall is not none else '—' }}</div>
          <div class="of">/ 5.0</div>
          <div class="lvl"><span class="b">Overall maturity</span>{% if overall_level.n %}Level {{ overall_level.n }} — {{ overall_level.label }}{% else %}Pending scoring{% endif %}{% if confidence is not none %} &nbsp;·&nbsp; {{ confidence }}% confidence{% endif %}</div>
        </div>
        <div class="foot"><span>{{ confidential }}</span><span>{{ firm.website.replace('https://','') }}</span></div>
      </div>
    </div>
  </div>

  <!-- STATEMENT -->
  <div class="statement">
    <div class="q">{% if overall is not none %}{{ client }}&rsquo;s {{ site }} operation scored
      {{ '%.2f'|format(overall) }} of 5.0 on the Reliability Maturity Index&mdash;{{ overall_level.label|lower }} maturity{% if top_pillar %},
      led by {{ top_pillar.name|lower }}{% endif %}{% if weakest %}, with {{ weakest.name|lower }} the clearest opportunity to advance{% endif %}.{% else %}
      An independent reliability maturity assessment of {{ client }}&rsquo;s {{ site }} operation across five domains and fifteen subdomains.{% endif %}</div>
    <div class="by">by <b>{{ lead_assessor if lead_assessor and lead_assessor != '—' else firm.name }}</b>{% if lead_assessor and lead_assessor != '—' %}, {{ firm.name }} Reliability Practice{% endif %}</div>

    <div class="stats">
      <div class="stat"><div class="v">{{ '%.2f'|format(overall) if overall is not none else '—' }}</div><div class="k">Overall RMI, of 5.0</div></div>
      {% if confidence is not none %}<div class="stat"><div class="v">{{ confidence }}%</div><div class="k">scoring confidence</div></div>{% endif %}
      <div class="stat"><div class="v">{{ responses }}</div><div class="k">role-weighted responses scored</div></div>
    </div>
    <div class="copyright">&copy; {{ report_date[-4:] }} {{ firm.name }}. {{ confidential }}. Prepared exclusively for {{ client }}. No part of this report may be reproduced without written consent.</div>
  </div>
</body>
</html>
