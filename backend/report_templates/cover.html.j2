<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<style>
{{ fonts_css }}
* { margin: 0; padding: 0; box-sizing: border-box; }
@page { size: Letter; margin: 0; }
html, body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
body { font-family: 'Inter', Arial, sans-serif; }

.cover {
  position: relative; width: 8.5in; height: 11in; overflow: hidden; color: #fff;
  background:
    radial-gradient(120% 80% at 78% 8%, rgba(28,120,181,0.34) 0%, rgba(28,120,181,0) 55%),
    radial-gradient(90% 70% at 12% 100%, rgba(11,79,147,0.42) 0%, rgba(11,79,147,0) 60%),
    linear-gradient(160deg, #07203c 0%, #061A31 48%, #040f1f 100%);
}
/* conveyor-slat motif */
.cover::before {
  content: ""; position: absolute; inset: 0;
  background-image: repeating-linear-gradient(115deg, rgba(188,193,195,0.05) 0 2px, transparent 2px 26px);
  opacity: 0.9;
}
/* faint blueprint grid bottom-right */
.cover::after {
  content: ""; position: absolute; right: -1.4in; bottom: -1.4in; width: 5.4in; height: 5.4in;
  border-radius: 50%;
  background:
    repeating-radial-gradient(circle at center, rgba(28,120,181,0.10) 0 1px, transparent 1px 14px);
  opacity: 0.55;
}
.edge { position: absolute; top: 0; left: 0; right: 0; height: 8px;
  background: linear-gradient(90deg, #0B4F93 0%, #1C78B5 50%, #BCC1C3 100%); }
.inner { position: relative; z-index: 2; height: 100%; padding: 0.95in 0.85in 0.7in; display: flex; flex-direction: column; }

.brandrow { display: flex; align-items: center; gap: 16px; }
.brandrow img { width: 72px; height: 72px; filter: drop-shadow(0 6px 16px rgba(0,0,0,0.45)); }
.brandrow .name { font-size: 20px; font-weight: 800; letter-spacing: .01em; }
.brandrow .tag { font-size: 10.5px; color: #9FB6CF; letter-spacing: .14em; text-transform: uppercase; margin-top: 3px; }

.titlewrap { margin-top: 1.5in; }
.eyebrow { font-size: 12px; letter-spacing: .42em; text-transform: uppercase; color: #6FA8D6; font-weight: 600; }
.title { font-size: 52px; line-height: 1.02; font-weight: 800; margin-top: 14px; letter-spacing: -0.015em; }
.title .light { color: #BCC1C3; font-weight: 300; }
.subtitle { font-size: 16px; color: #C7D5E5; margin-top: 18px; font-weight: 400; max-width: 5in; line-height: 1.5; }

.client { margin-top: 30px; }
.client .lbl { font-size: 10.5px; letter-spacing: .2em; text-transform: uppercase; color: #6FA8D6; }
.client .nm { font-size: 30px; font-weight: 700; margin-top: 5px; }
.client .st { font-size: 15px; color: #AFC2D6; margin-top: 2px; }

.scorecard { margin-top: auto; display: flex; align-items: center; gap: 26px;
  background: rgba(255,255,255,0.045); border: 1px solid rgba(188,193,195,0.18);
  border-radius: 16px; padding: 22px 26px; backdrop-filter: blur(2px); }
.gauge { position: relative; width: 124px; height: 124px; flex: none; }
.gauge .ring { width: 124px; height: 124px; border-radius: 50%;
  background: conic-gradient({{ overall_level.color }} 0% {{ ((overall or 0)/5*100)|round }}%, rgba(255,255,255,0.10) {{ ((overall or 0)/5*100)|round }}% 100%); }
.gauge .hole { position: absolute; inset: 11px; border-radius: 50%; background: #08203c;
  display: flex; flex-direction: column; align-items: center; justify-content: center; border: 1px solid rgba(188,193,195,0.18); }
.gauge .val { font-size: 34px; font-weight: 800; line-height: 1; }
.gauge .of { font-size: 11px; color: #9FB6CF; margin-top: 3px; }
.scoremeta .lvl { font-size: 20px; font-weight: 700; color: #fff; }
.scoremeta .lvlsub { font-size: 12px; color: #AFC2D6; letter-spacing: .04em; text-transform: uppercase; margin-top: 3px; }
.scoremeta .band { font-size: 12px; color: #C7D5E5; margin-top: 12px; }
.chip { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 600;
  color: #08203c; background: {{ overall_level.color }}; margin-top: 10px; }

.metagrid { margin-top: 24px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px;
  background: rgba(188,193,195,0.18); border: 1px solid rgba(188,193,195,0.18); border-radius: 10px; overflow: hidden; }
.metagrid .cell { background: #07203c; padding: 12px 14px; }
.metagrid .k { font-size: 9px; letter-spacing: .16em; text-transform: uppercase; color: #6FA8D6; }
.metagrid .v { font-size: 13px; font-weight: 600; margin-top: 4px; color: #EaF1F8; }

.foot { margin-top: 20px; display: flex; justify-content: space-between; align-items: center;
  font-size: 10.5px; color: #8AA3BE; border-top: 1px solid rgba(188,193,195,0.14); padding-top: 14px; }
.foot .conf { letter-spacing: .04em; }
</style>
</head>
<body>
  <div class="cover">
    <div class="edge"></div>
    <div class="inner">
      <div class="brandrow">
        {% if logo %}<img src="{{ logo }}" alt="NextBelt" />{% endif %}
        <div>
          <div class="name">{{ firm.name }}</div>
          <div class="tag">{{ firm.tagline }}</div>
        </div>
      </div>

      <div class="titlewrap">
        <div class="eyebrow">Reliability Maturity Index</div>
        <div class="title">Executive <span class="light">Audit Report</span></div>
        <div class="subtitle">An independent assessment of maintenance &amp; reliability maturity across People, Process, and Technology — evaluated over five domains and fifteen subdomains.</div>
      </div>

      <div class="client">
        <div class="lbl">Prepared for</div>
        <div class="nm">{{ client }}</div>
        <div class="st">{{ site }}{% if region and region != '—' %} &nbsp;·&nbsp; {{ region }}{% endif %}</div>
      </div>

      <div class="scorecard">
        <div class="gauge">
          <div class="ring"></div>
          <div class="hole">
            <div class="val">{{ '%.2f'|format(overall) if overall is not none else '—' }}</div>
            <div class="of">of 5.0</div>
          </div>
        </div>
        <div class="scoremeta">
          <div class="lvl">{% if overall_level.n %}Level {{ overall_level.n }} — {{ overall_level.label }}{% else %}Pending{% endif %}</div>
          <div class="lvlsub">Overall Reliability Maturity</div>
          {% if confidence is not none %}<span class="chip">{{ confidence }}% confidence</span>{% endif %}
          {% if confidence_band[0] is not none %}<div class="band">Confidence band {{ '%.2f'|format(confidence_band[0]) }} – {{ '%.2f'|format(confidence_band[1]) }}</div>{% endif %}
        </div>
      </div>

      <div class="metagrid">
        <div class="cell"><div class="k">Assessment Date</div><div class="v">{{ assessment_date }}</div></div>
        <div class="cell"><div class="k">Industry</div><div class="v">{{ industry }}</div></div>
        <div class="cell"><div class="k">Mode</div><div class="v">{{ mode }}</div></div>
        <div class="cell"><div class="k">Lead Assessor</div><div class="v">{{ lead_assessor }}</div></div>
      </div>

      <div class="foot">
        <span class="conf">{{ confidential }}</span>
        <span>{{ firm.website }}</span>
      </div>
    </div>
  </div>
</body>
</html>
